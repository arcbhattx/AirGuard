{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ML Model Output Schema",
  "type": "object",
  "properties": {
    "risk_level": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"],
      "description": "Categorical risk assessment"
    },
    "risk_probability": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Calibrated probability of risk"
    },
    "top_factors": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Features that contributed most significantly to the prediction"
    },
    "recommended_action": {
      "type": "string",
      "description": "Actionable advice based on the risk level"
    },
    "model_version": {
      "type": "string",
      "description": "Version identifier of the deployed model"
    }
  },
  "required": ["risk_level", "risk_probability", "top_factors", "recommended_action", "model_version"]
}
